{
  "name": "george-foreman",
  "version": "0.1.0",
  "description": "macOS Electron app for managing AI agent workflows",
  "main": "./out/main/index.js",
  "author": "pdoucefy",
  "homepage": ".",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate-icon": "python3 scripts/generate-icon.py",
    "package": "pnpm build && electron-builder --mac --config electron-builder.yml",
    "release": "jiti scripts/release.ts"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,yaml,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@fontsource/barlow": "^5.2.8",
    "@fontsource/barlow-condensed": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/rubik-distressed": "^5.2.7",
    "@radix-ui/react-select": "^2.3.1",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.1.7",
    "focus-trap-react": "^12.0.3",
    "js-yaml": "^5.1.0",
    "lucide-react": "^1.21.0",
    "styled-components": "^6.1.18",
    "zod": "^3.25.76",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/eslint-plugin-jsx-a11y": "^6.10.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/styled-components": "^5.1.34",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^3.1.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "happy-dom": "^20.10.6",
    "jiti": "^2.7.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26"
}
